# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# Google OAuth Credentials (create at https://console.cloud.google.com)
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Supabase Credentials (optional - only if using Supabase)
VITE_SUPABASE_URL="https://your_project.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"
VITE_DEMO_USER_ID="your_user_uuid_here"

# Encryption Key (generate 32+ random chars for AES-256)
ENCRYPTION_SECRET="your_32_char_random_encryption_secret_here"

# ManyChat API Key (from https://manychat.com → Settings → API)
MANYCHAT_API_KEY="your_manychat_api_key"
